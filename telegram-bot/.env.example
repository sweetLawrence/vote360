# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Base URL of your Physical Assets Service (no trailing slash)
API_BASE_URL=http://localhost:3001

# Shared secret sent as x-bot-secret header to authenticate bot requests
BOT_SECRET=your_bot_secret_here

# Google Gemini API key for AI photo analysis (optional — get free key at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here
